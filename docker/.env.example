# =============================================================================
# Globale Konfiguration
# =============================================================================
DOMAIN=isms.example.com
ACME_EMAIL=admin@example.com

# Traefik Dashboard (nur intern erreichbar, Passwort: htpasswd generieren)
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD_HASH=$apr1$xyz$...

# =============================================================================
# Forgejo
# =============================================================================
FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASSWORD=changeme_forgejo_db
FORGEJO_DB_NAME=forgejo
FORGEJO_SECRET_KEY=changeme_forgejo_secret_64chars
FORGEJO_INTERNAL_TOKEN=changeme_forgejo_internal_token

# =============================================================================
# OTOBO (Szenario A)
# =============================================================================
OTOBO_DB_ROOT_PASSWORD=changeme_otobo_root
OTOBO_DB_PASSWORD=changeme_otobo_db

# =============================================================================
# Plane (Szenario B)
# =============================================================================
PLANE_SECRET_KEY=changeme_plane_secret_50chars
PLANE_DB_USER=plane
PLANE_DB_PASSWORD=changeme_plane_db
PLANE_DB_NAME=plane
PLANE_REDIS_URL=redis://plane-redis:6379/

# =============================================================================
# DataGerry
# =============================================================================
DATAGERRY_DB_NAME=datagerry

# =============================================================================
# BookStack
# =============================================================================
BOOKSTACK_DB_USER=bookstack
BOOKSTACK_DB_PASSWORD=changeme_bookstack_db
BOOKSTACK_DB_NAME=bookstack
BOOKSTACK_APP_KEY=base64:changeme_32chars_base64encoded

# =============================================================================
# Wekan
# =============================================================================
WEKAN_DB_NAME=wekan
WEKAN_ROOT_URL=https://board.${DOMAIN}

# =============================================================================
# Authelia (Szenario A, optional)
# =============================================================================
AUTHELIA_JWT_SECRET=changeme_authelia_jwt_secret
AUTHELIA_SESSION_SECRET=changeme_authelia_session_secret
AUTHELIA_STORAGE_ENCRYPTION_KEY=changeme_authelia_storage_key_32chars
