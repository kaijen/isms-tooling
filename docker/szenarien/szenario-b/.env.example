# Szenario B – Supplier, KMU
# Minimaler Stack: Forgejo + Plane + DataGerry + Docs
# Kein Wiki, kein Kanban-Board – auf das Wesentliche reduziert

DOMAIN=isms.example.com
ACME_EMAIL=admin@example.com

TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD_HASH=$apr1$xyz$...

# Forgejo
FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASSWORD=
FORGEJO_DB_NAME=forgejo
FORGEJO_SECRET_KEY=
FORGEJO_INTERNAL_TOKEN=

# Plane
PLANE_SECRET_KEY=
PLANE_DB_USER=plane
PLANE_DB_PASSWORD=
PLANE_DB_NAME=plane
PLANE_REDIS_URL=redis://plane-redis:6379/

# DataGerry
DATAGERRY_DB_NAME=datagerry

# =============================================================================
# Demo / Seed-Skripte
# =============================================================================
FORGEJO_TOKEN=         # API-Token eines Forgejo-Admin-Users
DATAGERRY_TOKEN=       # API-Token aus DataGerry Admin-UI
PLANE_TOKEN=           # Plane API Key (Einstellungen → API Tokens)
