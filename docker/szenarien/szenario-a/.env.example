# Szenario A – Greenfield, NIS2-betroffen
# Vollständiger Stack: Forgejo + OTOBO + DataGerry + BookStack + Wekan + Docs
# Kopieren nach .env und alle Werte anpassen

DOMAIN=isms.example.com
ACME_EMAIL=admin@example.com

TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD_HASH=$apr1$xyz$...

# Forgejo
FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASSWORD=
FORGEJO_DB_NAME=forgejo
FORGEJO_SECRET_KEY=
FORGEJO_INTERNAL_TOKEN=

# OTOBO
OTOBO_DB_ROOT_PASSWORD=
OTOBO_DB_PASSWORD=

# DataGerry
DATAGERRY_DB_NAME=datagerry

# BookStack
BOOKSTACK_DB_USER=bookstack
BOOKSTACK_DB_PASSWORD=
BOOKSTACK_DB_NAME=bookstack
BOOKSTACK_APP_KEY=

# Wekan
WEKAN_DB_NAME=wekan
WEKAN_ROOT_URL=https://board.${DOMAIN}
